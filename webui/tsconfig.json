{
  "compilerOptions": {
    "allowJs": false,
    "module": "ESNext",
    "moduleResolution": "Bundler",
    "target": "ES2021",
    "lib": ["DOM", "DOM.Iterable", "ES2021"],
    "noEmit": true,
    "strict": true,
    "isolatedModules": true,
    "useDefineForClassFields": true,
    "skipLibCheck": true
  },
  "include": ["src/**/*", "worker.ts"]
}
